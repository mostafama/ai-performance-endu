# =============================================================================
# .env.template
# -------------
# Copy this file to .env and fill in your API keys before running the pipeline.
#
#   cp .env.template .env
#
# .env is loaded automatically by python-dotenv at the top of each script.
# Never commit .env to version control — add it to your .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# OpenAI — required for GPT models (gpt-4o-mini) and the judge (gpt-4.1-mini)
# Get your key at: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# Google — required for Gemini models (gemini-2.5-flash)
# Get your key at: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=


# -----------------------------------------------------------------------------
# Anthropic — required for Claude models (claude-sonnet-4.5, claude-3.5-sonnet)
# Get your key at: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# Groq — required for LLaMA models (llama-3.3-70b, llama-3.1-8b)
# Get your key at: https://console.groq.com/keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=


# -----------------------------------------------------------------------------
# OpenRouter — required for DeepSeek models (deepseek-v3.2)
# Get your key at: https://openrouter.ai/settings/keys
#
# OPENROUTER_SITE_URL and OPENROUTER_APP_NAME are optional but recommended —
# they appear in your OpenRouter usage dashboard to identify this project.
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://your-site.example
OPENROUTER_APP_NAME=EduQuestion3
